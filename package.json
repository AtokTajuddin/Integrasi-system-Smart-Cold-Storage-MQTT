{
  "name": "medicold-integrasi-sistem-mqtt",
  "version": "1.0.0",
  "description": "Smart cold storage integration over MQTT with streaming telemetry and retained messages.",
  "main": "src/server/core.js",
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "broker": "docker compose up broker",
    "compose": "docker compose up --build",
    "start": "node src/server/core.js",
    "admin": "node src/client/admin.js",
    "sensor": "node src/client/sensor.js",
    "dummy:sender": "node src/client/dummy_sender.js",
    "dashboard": "node src/client/dashboard.js",
    "dashboard:web": "vite --host 0.0.0.0",
    "dashboard:web:build": "vite build",
    "dashboard:web:preview": "vite preview --host 0.0.0.0",
    "mqtt:control": "node mqtt-control-tool.js",
    "mqtt:validate": "node validate-mqtt.js",
    "test": "node --test"
  },
  "keywords": [
    "mqtt",
    "cold-storage",
    "iot",
    "retain-message",
    "streaming"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.13"
  },
  "dependencies": {
    "animejs": "^4.4.1",
    "mqtt": "^5.15.1"
  },
  "devDependencies": {
    "vite": "^8.0.11"
  }
}
