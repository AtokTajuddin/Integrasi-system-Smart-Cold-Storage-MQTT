# =====================================================
# MQTT Broker Configuration
# =====================================================
MQTT_BROKER_URL=mqtt://localhost:1883
MQTT_BROKER_WS_URL=ws://localhost:9001
MQTT_TOPIC_ROOT=medicold

# =====================================================
# Node Environment
# =====================================================
NODE_ENV=development

# =====================================================
# Server Configuration
# =====================================================
CORE_LOG_LEVEL=info
CORE_TELEMETRY_INTERVAL=900

# =====================================================
# Dashboard Configuration
# =====================================================
DASHBOARD_PORT=5173
DASHBOARD_LOG_LEVEL=info

# =====================================================
# Security (untuk production - jangan commit!)
# =====================================================
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_BROKER_CERT_PATH=

# =====================================================
# Database (jika ditambah nanti)
# =====================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medicold
DB_USER=postgres
DB_PASSWORD=

# =====================================================
# Redis (opsional - hanya jika multi-node)
# =====================================================
REDIS_HOST=
REDIS_PORT=
REDIS_PASSWORD=

# =====================================================
# Feature Flags
# =====================================================
ENABLE_PERSISTENCE=false
ENABLE_AUDIT_LOG=false
ENABLE_DATA_ARCHIVE=false

# =====================================================
# SETUP INSTRUCTIONS
# =====================================================
# 1. Copy .env.example ke .env (untuk shared defaults)
#    cp .env.example .env
#
# 2. Copy .env.example ke .env.local (untuk development overrides)
#    cp .env.example .env.local
#
# 3. Edit .env.local dengan nilai lokal Anda
#
# 4. JANGAN commit .env atau .env.local (sudah di .gitignore)
#
# 5. Jalankan:
#    docker compose --env-file .env.local up
# =====================================================
